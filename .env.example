# Vy Web Environment Configuration
# Copy this file to .env and fill in your actual values

# Required API Keys - You must provide these
VY_LLM_API_KEY=your_openai_api_key_here
VY_GOOGLE_API_KEY=your_google_api_key_here
VY_GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id_here

# Optional: Use different API key for embeddings (defaults to VY_LLM_API_KEY)
VY_VECTOR_MEMORY_OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration (these have sensible defaults)
VY_LLM_MODEL_ID=gpt-4o-mini
VY_MEMORY_MODEL_ID=gpt-4o-mini
VY_MEMORY_SIMILARITY_MODEL_ID=gpt-4o-mini
VY_EMBEDDING_MODEL=text-embedding-3-small

# Application Settings
VY_DEFAULT_CHAT_MODE=web
VY_SYSTEM_PROMPT=

# Vector Memory Configuration
VY_QDRANT_URL=http://localhost:6333
VY_QDRANT_API_KEY=
VY_COLLECTION_NAME=vy_memories

# Server Configuration (for local development)
HOST=0.0.0.0
PORT=3001

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Get your OpenAI API key from: https://platform.openai.com/api-keys
# 3. Get your Google API key from: https://console.cloud.google.com/apis/credentials
# 4. Create a Google Custom Search Engine at: https://cse.google.com/cse/
# 5. Fill in the actual values above
# 6. Keep .env file private and never commit it to version control
